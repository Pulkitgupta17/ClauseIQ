# ClauseIQ configuration — copy to `.env` and fill in.
# All variables use the CLAUSEIQ_ prefix and are parsed by src/clauseiq/config.py.
# Every value has a safe default; only the secrets truly need setting for full
# functionality. The data pipeline (ingestion + retrieval) runs with NONE of the
# LLM/Langfuse secrets set.

# --- LLMs (Google AI Studio, free tier) -------------------------------------
# Get a key at https://aistudio.google.com/app/apikey
CLAUSEIQ_GEMINI_API_KEY=
CLAUSEIQ_ORCHESTRATION_MODEL=gemini-2.0-flash
CLAUSEIQ_ANALYSIS_MODEL=gemini-2.5-pro

# --- Embeddings (local, free) -----------------------------------------------
CLAUSEIQ_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Vector store (ChromaDB) ------------------------------------------------
CLAUSEIQ_CHROMA_HOST=localhost
CLAUSEIQ_CHROMA_PORT=8000
CLAUSEIQ_CHROMA_COLLECTION_LAW=indian_law
CLAUSEIQ_CHROMA_PERSIST_DIR=data/chroma

# --- Chunking (aligned to all-MiniLM-L6-v2's 256-token window) --------------
CLAUSEIQ_CHUNK_MAX_TOKENS=250
CLAUSEIQ_CHUNK_OVERLAP_TOKENS=25

# --- Law corpus (committed JSON = source of truth) --------------------------
CLAUSEIQ_LAW_CORPUS_PATH=data/laws/indian_contract_act_1872.json
# Leave blank to derive from the corpus JSON's top-level "version" field.
CLAUSEIQ_CORPUS_VERSION=

# --- Observability (Langfuse, self-hosted) ----------------------------------
CLAUSEIQ_LANGFUSE_PUBLIC_KEY=
CLAUSEIQ_LANGFUSE_SECRET_KEY=
CLAUSEIQ_LANGFUSE_HOST=http://localhost:3000

# --- Eval thresholds --------------------------------------------------------
CLAUSEIQ_FAITHFULNESS_THRESHOLD=0.85
CLAUSEIQ_CONTEXT_RECALL_THRESHOLD=0.80

# --- Runtime / logging ------------------------------------------------------
CLAUSEIQ_LOG_LEVEL=INFO
CLAUSEIQ_LOG_JSON=true
CLAUSEIQ_ENVIRONMENT=dev
