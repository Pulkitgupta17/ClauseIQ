# Build context hygiene — keep the image lean and the build reproducible.
.git/
.github/
.venv/
__pycache__/
**/__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
htmlcov/

# Generated / local data (the committed corpus under data/laws IS included).
data/chroma/
.docker-data/

# Not needed in the backend image.
frontend/
docs/
tests/
scripts/
*.md
!README.md
.env
.env.*
!.env.example
claude*.prompt
claude*.md
